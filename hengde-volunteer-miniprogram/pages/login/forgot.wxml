<view class="forgot-page">
  <view class="forgot-nav">
    <image class="forgot-back" src="{{icons.back}}" mode="aspectFit" bindtap="goBack"></image>
    <view class="forgot-title">忘记密码</view>
  </view>

  <view style="padding: 40rpx 48rpx;">
    <view style="display:flex; align-items:center; border-bottom:2rpx solid #eeeeee; padding:20rpx 0;">
      <input style="flex:1; font-size:30rpx;" type="number" placeholder="请输入手机号" data-field="phone" value="{{phone}}" bindinput="updateField" />
    </view>
    <view style="display:flex; align-items:center; border-bottom:2rpx solid #eeeeee; padding:20rpx 0;">
      <input style="flex:1; font-size:30rpx;" type="number" placeholder="请输入验证码" data-field="smsCode" value="{{smsCode}}" bindinput="updateField" />
      <view style="color:#1677ff; font-size:28rpx; padding-left:20rpx;" bindtap="getSmsCode">{{sending ? '发送中…' : '获取验证码'}}</view>
    </view>
    <view style="display:flex; align-items:center; border-bottom:2rpx solid #eeeeee; padding:20rpx 0;">
      <input style="flex:1; font-size:30rpx;" password placeholder="设置新密码（6-32位）" data-field="newPassword" value="{{newPassword}}" bindinput="updateField" />
    </view>
    <button class="confirm-btn" style="margin-top:60rpx;" loading="{{submitting}}" disabled="{{submitting}}" bindtap="confirm">确认重置</button>
  </view>
</view>
