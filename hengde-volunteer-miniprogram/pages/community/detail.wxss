.community-detail-page {
  padding: 0 30rpx 34rpx;
  background: linear-gradient(180deg, #ff8cab 0%, #ffd5da 24%, #fbefec 100%);
}

.detail-header {
  height: 92rpx;
  margin: 0 -30rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.36);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 32rpx;
  top: 12rpx;
  color: #222222;
  font-size: 58rpx;
  font-weight: 700;
}

.detail-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
}

.detail-post-card,
.comment-card {
  position: relative;
  margin: 0 10rpx 24rpx;
  padding: 24rpx 30rpx 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.16);
}

.post-more {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  color: #666666;
  font-size: 34rpx;
  letter-spacing: 4rpx;
}

.post-head,
.comment-input-row,
.comment-item,
.reply-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.avatar,
.comment-avatar {
  width: 70rpx;
  height: 70rpx;
  flex: none;
}

.reply-avatar {
  width: 44rpx;
  height: 44rpx;
  flex: none;
}

.nickname-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nickname,
.comment-name,
.reply-name {
  color: #2346b8;
  font-size: 24rpx;
  font-weight: 700;
}

.follow-btn {
  min-width: 94rpx;
  height: 28rpx;
  line-height: 28rpx;
  border: 2rpx solid #ff2222;
  border-radius: 4rpx;
  color: #ff2222;
  text-align: center;
  font-size: 21rpx;
  box-sizing: border-box;
}

.post-time,
.comment-time {
  margin-top: 4rpx;
  color: #111111;
  font-size: 24rpx;
}

.post-content {
  margin-top: 20rpx;
  color: #111111;
  font-size: 27rpx;
  font-weight: 700;
}

.media-image {
  width: 250rpx;
  height: 190rpx;
  margin-top: 28rpx;
  border-radius: 22rpx;
  background: #f15d5d;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-image-icon {
  width: 188rpx;
  height: 148rpx;
}

.post-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 22rpx;
  color: #ff6f78;
  font-size: 25rpx;
}

.comment-count {
  margin-bottom: 18rpx;
  color: #111111;
  font-size: 27rpx;
  font-weight: 700;
}

.comment-input-row {
  align-items: center;
  margin-bottom: 24rpx;
}

.comment-input {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  padding-left: 24rpx;
  border: 2rpx solid #777777;
  border-radius: 12rpx;
  color: #111111;
  font-size: 26rpx;
}

.comment-image-btn {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin-left: -72rpx;
  color: #111111;
  text-align: center;
  font-size: 30rpx;
}

.comment-item {
  position: relative;
  margin-top: 22rpx;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-text,
.reply-text {
  color: #111111;
  font-size: 24rpx;
  line-height: 1.35;
}

.reply-item {
  margin-top: 10rpx;
}

.reply-to {
  color: #7b4ad1;
}

.more-reply {
  margin-top: 10rpx;
  color: #111111;
  font-size: 24rpx;
}

.heart {
  color: #ff6f78;
  font-size: 44rpx;
}
