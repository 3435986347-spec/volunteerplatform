<view class="page community-detail-page">
  <view class="detail-header">
    <view class="back-btn" bindtap="goBack">↩</view>
    <view class="detail-title">详情页</view>
  </view>

  <view class="detail-post-card">
    <view class="post-more">•••</view>
    <view class="post-head">
      <image class="avatar" src="{{logoIcon}}" mode="aspectFit"></image>
      <view class="post-user">
        <view class="nickname-line">
          <text class="nickname">这是昵称</text>
          <text class="follow-btn">关注</text>
        </view>
        <view class="post-time">2025/03/05 12:00</view>
      </view>
    </view>
    <view class="post-content">这道题怎么写</view>
    <view class="media-image">
      <image class="media-image-icon" src="{{imageIcon}}" mode="aspectFit"></image>
    </view>
    <view class="post-actions">
      <text class="action">◎321</text>
      <text class="action">⌯3</text>
      <text class="action">▰20</text>
      <text class="action">▢30</text>
    </view>
  </view>

  <view class="comment-card">
    <view class="comment-count">共30条评论⌄</view>
    <view class="comment-input-row">
      <image class="comment-avatar" src="{{logoIcon}}" mode="aspectFit"></image>
      <view class="comment-input">发表你的观点吧</view>
      <view class="comment-image-btn">▧+</view>
    </view>

    <view class="comment-item" wx:for="{{comments}}" wx:key="nickname">
      <image class="comment-avatar" src="{{logoIcon}}" mode="aspectFit"></image>
      <view class="comment-body">
        <view class="comment-name">{{item.nickname}}</view>
        <view class="comment-text">{{item.content}}</view>
        <view class="comment-time">{{item.time}}</view>
        <view class="reply-item" wx:for="{{item.replies}}" wx:for-item="reply" wx:key="nickname">
          <image class="reply-avatar" src="{{logoIcon}}" mode="aspectFit"></image>
          <view>
            <view class="reply-name">{{reply.nickname}} <text class="reply-to">› 我是空气</text></view>
            <view class="reply-text">{{reply.content}}</view>
            <view class="comment-time">{{reply.time}}</view>
          </view>
        </view>
        <view class="more-reply" wx:if="{{item.replies.length}}">展开3条评论⌄</view>
      </view>
      <view class="heart">♡</view>
    </view>
  </view>
</view>
