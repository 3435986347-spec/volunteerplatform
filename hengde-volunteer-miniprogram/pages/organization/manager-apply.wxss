.apply-page {
  min-height: 100vh;
  padding-bottom: 56rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ff91ad 0%, #ffc6ce 36%, #fbf3ef 100%);
  color: #050505;
  font-family: "KaiTi", "STKaiti", "Songti SC", serif;
}

.topbar {
  position: relative;
  height: calc(env(safe-area-inset-top) + 104rpx);
  padding-top: env(safe-area-inset-top);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.28);
  background: linear-gradient(180deg, #ff86a7 0%, #ffa5b7 100%);
  box-sizing: border-box;
}

.back-icon {
  position: absolute;
  left: 32rpx;
  bottom: 22rpx;
  width: 60rpx;
  height: 60rpx;
}

.top-title {
  font-size: 38rpx;
  font-weight: 700;
}

.hero-space {
  height: 200rpx;
}

.status-card,
.apply-card,
.applicant-card {
  width: 86%;
  margin: 0 auto 16rpx;
  border: 3rpx solid #e4e4e4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.status-card {
  padding: 22rpx 34rpx;
  font-size: 30rpx;
  line-height: 1.5;
}

.status-line {
  font-weight: 800;
}

.status-reason {
  color: #d4380d;
}

.status-hint {
  color: #6b7280;
  font-size: 27rpx;
}

.apply-card {
  padding: 22rpx 42rpx 26rpx;
}

.form-line {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  font-size: 31rpx;
  font-weight: 700;
}

.form-line text {
  flex: none;
}

.req {
  color: #f4587a;
}

.form-line input {
  flex: 1;
  min-width: 0;
  height: 54rpx;
  color: #000000;
  font-size: 29rpx;
  font-weight: 700;
}

.intro-line {
  align-items: flex-start;
}

.intro-line textarea {
  flex: 1;
  min-width: 0;
  height: 96rpx;
  color: #000000;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.dark-placeholder {
  color: #111111;
  font-weight: 400;
}

.applicant-card {
  padding: 20rpx 34rpx;
  font-size: 30rpx;
  line-height: 1.38;
}

.applicant-title {
  font-weight: 800;
}

.submit-btn {
  width: 86%;
  height: 78rpx;
  margin: 18rpx auto 0;
  padding: 0;
  border: 0;
  border-radius: 14rpx;
  background: #f3bcc8;
  color: #000000;
  font-size: 30rpx;
  line-height: 78rpx;
}

.submit-btn::after {
  border: 0;
}
