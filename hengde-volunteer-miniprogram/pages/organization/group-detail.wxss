.detail-page {
  min-height: 100vh;
  padding-bottom: 46rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ff91ad 0%, #ffc9d0 22%, #fbf3ef 100%);
  color: #050505;
  font-family: "KaiTi", "STKaiti", "Songti SC", serif;
}

.topbar {
  position: relative;
  height: calc(env(safe-area-inset-top) + 104rpx);
  padding-top: env(safe-area-inset-top);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.28);
  background: linear-gradient(180deg, #ff86a7 0%, #ffa5b7 100%);
  box-sizing: border-box;
}

.back-icon {
  position: absolute;
  left: 32rpx;
  bottom: 22rpx;
  width: 60rpx;
  height: 60rpx;
}

.top-title {
  font-size: 38rpx;
  font-weight: 700;
}

.join-banner {
  width: 86%;
  height: 220rpx;
  margin: 24rpx 7% 20rpx;
  border-radius: 30rpx;
  display: block;
  background: #eaf8ee;
}

.join-card,
.summary-card,
.member-card,
.manage-action,
.application-card,
.log-card {
  border: 3rpx solid #e4e4e4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.04);
}

.join-card {
  position: relative;
  width: 86%;
  min-height: 228rpx;
  margin: 0 auto;
  padding: 28rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.join-logo {
  position: absolute;
  left: 36rpx;
  top: 48rpx;
  width: 112rpx;
  height: 112rpx;
}

.join-info {
  padding-left: 160rpx;
  padding-right: 42rpx;
  font-size: 26rpx;
  line-height: 1.35;
}

.join-name {
  font-size: 31rpx;
  font-weight: 800;
}

.copy-btn {
  display: inline-flex;
  width: 50rpx;
  height: 24rpx;
  margin-left: 8rpx;
  padding: 0;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1c1c1c;
  border-radius: 4rpx;
  background: #ffffff;
  color: #111111;
  font-size: 17rpx;
  line-height: 22rpx;
  vertical-align: middle;
}

.copy-btn::after {
  border: 0;
}

.qr-icon {
  position: absolute;
  right: 26rpx;
  top: 28rpx;
  width: 44rpx;
  height: 44rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6rpx;
}

.qr-icon view {
  border: 4rpx solid #111111;
  border-radius: 3rpx;
}

.join-intro {
  margin-top: 20rpx;
  font-size: 25rpx;
}

.more-actions {
  width: 86%;
  margin: 16rpx auto 0;
  display: flex;
  justify-content: flex-end;
  gap: 34rpx;
  color: #e85b64;
  font-size: 28rpx;
}

.join-btn {
  width: 74%;
  height: 78rpx;
  margin: 72rpx auto 0;
  padding: 0;
  border: 0;
  border-radius: 14rpx;
  background: #f3bcc8;
  color: #000000;
  font-size: 30rpx;
  line-height: 78rpx;
}

.join-btn::after,
.edit-submit::after,
.approval-actions button::after,
.pager button::after {
  border: 0;
}

.summary-card {
  width: 86%;
  margin: 24rpx auto 18rpx;
  padding: 22rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-sizing: border-box;
}

.summary-left {
  flex: none;
  width: 112rpx;
  text-align: center;
}

.summary-no {
  margin-bottom: 8rpx;
  font-size: 25rpx;
}

.summary-logo {
  width: 104rpx;
  height: 104rpx;
}

.summary-info {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.35;
}

.summary-name {
  font-size: 31rpx;
  font-weight: 800;
}

.edit-icon {
  margin-left: 8rpx;
  color: #ff6678;
  font-size: 36rpx;
}

.tabbar {
  width: 86%;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: end;
}

.tab-item {
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000000;
  font-size: 28rpx;
  font-weight: 700;
}

.tab-item.active {
  border-radius: 14rpx 14rpx 0 0;
  background: #ffffff;
  color: #ff122a;
  text-decoration: underline;
  text-decoration-thickness: 5rpx;
  text-underline-offset: 10rpx;
}

.tab-panel {
  width: 86%;
  margin: 0 auto;
}

.member-card {
  margin-bottom: 14rpx;
  padding: 20rpx 28rpx;
  font-size: 27rpx;
  line-height: 1.35;
}

.member-line {
  display: flex;
  gap: 54rpx;
  flex-wrap: wrap;
}

.manage-action {
  height: 86rpx;
  margin-bottom: 14rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  font-size: 29rpx;
  box-sizing: border-box;
}

.application-card {
  min-height: 86rpx;
  margin-bottom: 14rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 27rpx;
  box-sizing: border-box;
}

.fake-check {
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #f0b3bd;
  box-sizing: border-box;
}

.fake-check.checked,
.popup-check.checked {
  border-color: #f48da3;
  background: linear-gradient(135deg, transparent 45%, #f05d78 46%, #f05d78 60%, transparent 61%);
}

.approval-actions {
  margin: 340rpx auto 26rpx;
  display: flex;
  justify-content: center;
  gap: 70rpx;
}

.approval-actions button {
  width: 132rpx;
  height: 70rpx;
  padding: 0;
  border: 0;
  border-radius: 10rpx;
  background: #f5b9c6;
  color: #000000;
  font-size: 29rpx;
  line-height: 70rpx;
}

.approval-actions button:last-child {
  color: #e71934;
}

.log-card {
  padding: 26rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.log-row {
  margin-bottom: 24rpx;
}

.hot {
  color: #df132a;
}

.activity-link {
  color: #1f5aa8;
}

.pager {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14rpx;
  font-size: 25rpx;
}

.pager button {
  height: 34rpx;
  margin: 0;
  padding: 0 8rpx;
  border: 2rpx solid #111111;
  border-radius: 4rpx;
  background: #ffffff;
  font-size: 22rpx;
  line-height: 30rpx;
}

.pager .current {
  color: #e71934;
}

.popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.08);
}

.member-popup,
.edit-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  min-height: 560rpx;
  padding: 24rpx 34rpx 58rpx;
  border: 3rpx solid #eeeeee;
  border-radius: 38rpx 38rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
  font-family: "KaiTi", "STKaiti", "Songti SC", serif;
}

.popup-head {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  align-items: center;
  color: #000000;
  font-size: 30rpx;
  text-align: center;
}

.popup-head view:first-child {
  text-align: left;
}

.popup-head view:last-child {
  text-align: right;
}

.popup-head .confirm {
  color: #5b8ee9;
}

.popup-search,
.edit-input {
  width: 100%;
  height: 64rpx;
  margin-top: 34rpx;
  border: 4rpx solid #111111;
  border-radius: 999rpx;
  color: #000000;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.dark-placeholder {
  color: #111111;
}

.picker-member {
  min-height: 88rpx;
  margin-top: 24rpx;
  padding: 16rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border: 4rpx solid #111111;
  border-radius: 14rpx;
  color: #000000;
  font-size: 25rpx;
  line-height: 1.35;
  box-sizing: border-box;
}

.picker-member.selected {
  border-color: #f48da3;
}

.popup-check {
  flex: none;
  width: 36rpx;
  height: 36rpx;
  border: 5rpx solid #111111;
  box-sizing: border-box;
}

.edit-popup {
  min-height: 620rpx;
}

.cooldown {
  margin-top: 18rpx;
  text-align: center;
  color: #000000;
  font-size: 24rpx;
}

.upload-icon {
  width: 92rpx;
  height: 92rpx;
  margin: 64rpx auto 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #333333;
  color: #333333;
  font-size: 38rpx;
  overflow: hidden;
}

.upload-icon image {
  width: 100%;
  height: 100%;
}

.edit-input {
  margin-top: 0;
  border-color: #e8e8e8;
  border-radius: 14rpx;
}

.edit-submit {
  width: 100%;
  height: 80rpx;
  margin-top: 34rpx;
  padding: 0;
  border: 0;
  border-radius: 12rpx;
  background: #f8d5dc;
  color: #000000;
  font-size: 30rpx;
  line-height: 80rpx;
}
