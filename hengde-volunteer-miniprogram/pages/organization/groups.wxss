.group-page {
  min-height: 100vh;
  padding-bottom: 160rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ff91ad 0%, #ffc9d0 22%, #fbf3ef 100%);
  color: #070707;
  font-family: "KaiTi", "STKaiti", "Songti SC", serif;
}

.topbar {
  position: relative;
  height: calc(env(safe-area-inset-top) + 104rpx);
  padding-top: env(safe-area-inset-top);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.28);
  background: linear-gradient(180deg, #ff86a7 0%, #ffa5b7 100%);
  box-sizing: border-box;
}

.back-icon {
  position: absolute;
  left: 32rpx;
  bottom: 22rpx;
  width: 60rpx;
  height: 60rpx;
}

.top-title {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.search-wrap {
  width: 85%;
  height: 66rpx;
  margin: 26rpx auto 22rpx;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.search-input {
  height: 100%;
  padding: 0 32rpx;
  color: #ffffff;
  font-size: 31rpx;
  text-align: center;
  box-sizing: border-box;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.95);
}

.group-list {
  padding: 0 34rpx;
}

.group-card {
  position: relative;
  min-height: 160rpx;
  margin-bottom: 24rpx;
  padding: 22rpx 18rpx 22rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border: 3rpx solid #e4e4e4;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.card-left {
  flex: none;
  width: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.group-no {
  width: 100%;
  font-size: 28rpx;
  font-weight: 700;
  text-align: left;
}

.group-logo {
  width: 82rpx;
  height: 82rpx;
}

.card-main {
  flex: 1;
  min-width: 0;
  padding-right: 100rpx;
}

.group-name {
  margin-bottom: 6rpx;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-line {
  font-size: 27rpx;
  line-height: 1.28;
}

.apply-btn {
    position: absolute;
    right: 18rpx;
    top: 62rpx;

    width: 78rpx !important;
    min-width: 0 !important;
    max-width: 78rpx;
    height: 36rpx;

    padding: 0 !important;
    margin: 0;
    box-sizing: border-box;

    display: flex;
    align-items: center;
    justify-content: center;

    border: 0;
    border-radius: 7rpx;
    background: #f5b9c6;
    color: #e84f68;
    font-size: 23rpx;
    line-height: 36rpx;
  }

.apply-btn::after,
.create-btn::after {
  border: 0;
}

.empty-text {
  margin-top: 80rpx;
  color: #7a6d6d;
  font-size: 28rpx;
  text-align: center;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 30rpx;
  padding: 0 36rpx calc(env(safe-area-inset-bottom) + 8rpx);
  box-sizing: border-box;
}

.create-btn {
  width: 100%;
  height: 82rpx;
  padding: 0;
  border: 0;
  border-radius: 14rpx;
  background: #f3bcc8;
  color: #000000;
  font-size: 30rpx;
  line-height: 82rpx;
}
