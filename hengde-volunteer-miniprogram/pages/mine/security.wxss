.security-page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background: linear-gradient(180deg, #ff91ad 0%, #ffe0e5 28%, #fbf4f1 100%);
  color: #111111;
  font-family: "KaiTi", "STKaiti", "Songti SC", serif;
}

.security-nav {
  position: relative;
  height: calc(env(safe-area-inset-top) + 104rpx);
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.24);
  background: linear-gradient(180deg, #ff86a7 0%, #ffa5b7 100%);
}

.back-icon {
  position: absolute;
  left: 32rpx;
  bottom: 22rpx;
  width: 60rpx;
  height: 60rpx;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 700;
}

.security-list,
.form-card {
  width: 86%;
  margin: 22rpx auto 0;
}

.security-item,
.contact-card,
.protocol-item,
.suggest-card,
.form-card,
.cancel-dialog {
  border: 3rpx solid #e7e7e7;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.security-item {
  min-height: 84rpx;
  margin-bottom: 14rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
}

.security-item.danger {
  color: #d83b3b;
}

.form-card {
  padding: 20rpx 22rpx 24rpx;
}

.field {
  font-size: 30rpx;
  font-weight: 800;
}

.input,
.textarea {
  width: 100%;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.textarea {
  min-height: 150rpx;
}

.primary-btn,
.secondary-btn,
.small-btn {
  border: 0;
  border-radius: 14rpx;
  background: #f3bcc8;
  color: #000000;
  font-size: 28rpx;
}

.primary-btn {
  width: 100%;
  height: 78rpx;
  margin-top: 18rpx;
  line-height: 78rpx;
}

.secondary-btn {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
}

.small-btn {
  width: 120rpx;
  height: 56rpx;
  margin-top: 18rpx;
  line-height: 56rpx;
}

.about-text {
  margin-top: 18rpx;
  font-size: 28rpx;
}

.contact-card,
.protocol-item,
.suggest-card {
  margin-top: 14rpx;
  padding: 18rpx 18rpx;
  font-size: 26rpx;
}

.signature-name {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.signature-board {
  height: 260rpx;
  margin-top: 18rpx;
  border: 2rpx dashed #e9b0bc;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f98;
}

.action-row,
.sheet-buttons,
.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.protocol-detail {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.list-head {
  width: 86%;
  margin: 22rpx auto 0;
  display: flex;
  justify-content: space-between;
}

.suggest-title {
  font-size: 28rpx;
  font-weight: 800;
}

.suggest-status,
.view-link {
  margin-top: 10rpx;
  color: #d83b3b;
}

.detail-line {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.type-row {
  display: flex;
  gap: 24rpx;
  margin-top: 14rpx;
  font-size: 26rpx;
}

.cancel-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.12);
}

.cancel-dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  z-index: 21;
  width: 86%;
  transform: translate(-50%, -50%);
  padding: 22rpx;
}

.dialog-title {
  font-size: 30rpx;
  font-weight: 800;
}

.dialog-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
}
