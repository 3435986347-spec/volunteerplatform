.register-page {
  min-height: 100vh;
  padding: 0;
  background: #ffffff;
}

.register-shell {
  min-height: 100vh;
  padding-bottom: 40rpx;
  border: 2rpx solid #1f1f1f;
  box-sizing: border-box;
  background: #ffffff;
}

.register-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 86rpx;
  border-bottom: 1rpx solid #808080;
}

.back-icon {
  position: absolute;
  left: 34rpx;
  width: 54rpx;
  height: 54rpx;
}

.register-title {
  color: #000000;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.stepper {
  display: grid;
  grid-template-columns: 62rpx 96rpx 62rpx;
  align-items: start;
  justify-content: center;
  column-gap: 0;
  padding-top: 14rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 42rpx;
  height: 42rpx;
  border: 3rpx solid #222222;
  border-radius: 50%;
  box-sizing: border-box;
  color: #000000;
  line-height: 36rpx;
  text-align: center;
  font-size: 30rpx;
  background: #ffffff;
}

.step.active .step-circle {
  border-color: #f4b9c8;
  background: #f4b9c8;
  color: #ffffff;
}

.step-text {
  margin-top: 8rpx;
  color: #000000;
  font-size: 27rpx;
}

.step-line {
  height: 2rpx;
  margin-top: 21rpx;
  background: #e5e5e5;
}

.register-form {
  padding: 22rpx 46rpx 0;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 69rpx;
  border-bottom: 1rpx solid #e5e5e5;
  box-sizing: border-box;
}

.form-label {
  position: relative;
  flex: 0 0 225rpx;
  color: #000000;
  font-size: 30rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.form-label.required::before {
  content: "*";
  position: absolute;
  left: -18rpx;
  top: 0;
  color: #ff0000;
  font-size: 28rpx;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  color: #000000;
  font-size: 30rpx;
}

.form-input::placeholder {
  color: #8b8f98;
}

.picker-input {
  display: flex;
  align-items: center;
  width: 0;
  box-sizing: border-box;
  padding-right: 48rpx;
}

.picker-content {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.picker-value {
  color: #000000;
  font-size: 30rpx;
  line-height: 68rpx;
  white-space: nowrap;
}

.picker-value.placeholder {
  color: #8b8f98;
}

.picker-content .row-arrow {
  flex: 0 0 38rpx;
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: #000000;
  text-align: right;
  font-size: 58rpx;
  line-height: 58rpx;
}

.locate-btn {
  flex: 0 0 140rpx;
  width: 140rpx;
  height: 48rpx;
  margin: 0 0 0 12rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 24rpx;
  background: #f8d7dd;
  box-sizing: border-box;
  color: #000000;
  line-height: 1;
  text-align: center;
  font-size: 21rpx;
}

.locate-btn::after {
  border: 0;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-row .form-label {
  flex: 0 0 215rpx;
}

.action-row .form-input {
  flex: 1;
  width: 0;
  min-width: 0;
}

.pill-btn {
  flex: 0 0 140rpx;
  width: 140rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 24rpx;
  background: #f8d7dd;
  box-sizing: border-box;
  color: #000000;
  line-height: 1;
  text-align: center;
  font-size: 21rpx;
}

.pill-btn::after {
  border: 0;
}

.pill-btn[disabled] {
  background: #f8d7dd;
  color: #666666;
  opacity: 0.75;
}

.confirm-btn {
  width: 140rpx;
}

.phone-locked-tip {
  flex: 0 0 140rpx;
  width: 140rpx;
  text-align: center;
  color: #4caf50;
  font-size: 21rpx;
}

.picker-row {
  position: relative;
  padding-right: 0;
}

.row-arrow {
  flex: 0 0 38rpx;
  color: #000000;
  text-align: right;
  font-size: 58rpx;
  line-height: 58rpx;
}

.address-row .form-label {
  flex-basis: 225rpx;
}

.upload-row {
  padding-top: 24rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.upload-row .form-label {
  margin-bottom: 16rpx;
}

.upload-box {
  width: 96rpx;
  height: 96rpx;
  margin-left: 10rpx;
  margin-bottom: 28rpx;
  border: 4rpx solid #7f7f7f;
  box-sizing: border-box;
  background: #ffffff;
}

.plus-icon {
  position: relative;
  width: 100%;
  height: 100%;
}

.plus-icon::before,
.plus-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 58rpx;
  height: 5rpx;
  border-radius: 4rpx;
  background: #777777;
  transform: translate(-50%, -50%);
}

.plus-icon::after {
  width: 5rpx;
  height: 58rpx;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.agreement-card {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #f1c6d0;
  border-radius: 18rpx;
  background: #fff8fa;
}

.agreement-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.agreement-title {
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 28rpx;
  font-weight: 700;
}

.agreement-link {
  flex: none;
  color: #d83b3b;
  font-size: 24rpx;
}

.agreement-summary {
  margin-top: 14rpx;
  color: #596273;
  font-size: 24rpx;
  line-height: 1.55;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.agreement-check {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  color: #222222;
  font-size: 24rpx;
}

.signature-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.signature-label {
  position: relative;
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 26rpx;
}

.signature-label.required::before {
  content: "*";
  position: absolute;
  left: -18rpx;
  top: 0;
  color: #ff0000;
  font-size: 28rpx;
}

.signature-box {
  flex: none;
  width: 190rpx;
  height: 82rpx;
  border: 2rpx dashed #f58ca8;
  border-radius: 14rpx;
  background: #ffffff;
  overflow: hidden;
}

.signature-preview {
  width: 100%;
  height: 100%;
}

.signature-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d83b3b;
  font-size: 24rpx;
}

.next-btn {
  width: 500rpx;
  height: 76rpx;
  margin: 46rpx auto 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 38rpx;
  background: #f8d7dd;
  box-sizing: border-box;
  color: #000000;
  line-height: 1;
  font-size: 30rpx;
}

.next-btn::after {
  border: 0;
}
