.notice-card {
  padding: 24rpx;
  margin-top: 18rpx;
}

.notice-cover {
  width: 100%;
  height: 200rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  background: #f5f7fb;
}

.notice-title {
  max-width: 500rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.notice-summary {
  margin: 14rpx 0;
  line-height: 1.6;
  color: #596273;
}
