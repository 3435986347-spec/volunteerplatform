.notice-detail {
  padding: 28rpx;
}

.title {
  margin: 18rpx 0 10rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
}

.mock-image {
  height: 260rpx;
  margin: 28rpx 0;
  border-radius: 12rpx;
  background: #2f6fb2;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notice-image {
  width: 100%;
  height: 260rpx;
  margin: 28rpx 0;
  border-radius: 12rpx;
  background: #f5f7fb;
}

.body {
  line-height: 1.75;
  color: #4b5563;
}

.link-btn {
  height: 76rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #ffd0da;
  color: #111111;
  line-height: 76rpx;
  font-size: 28rpx;
}

.link-btn::after {
  border: 0;
}
