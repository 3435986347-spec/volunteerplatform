.activity-page {
  min-height: 100vh;
  padding: 0 40rpx 52rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ff8faf 0%, #ffc3cf 30%, #fff8f5 100%);
  color: #000000;
}

.activity-header {
  position: relative;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.36);
}

.back-icon {
  position: absolute;
  left: 0;
  width: 58rpx;
  height: 58rpx;
}

.activity-page-title {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.search-box {
  height: 66rpx;
  margin: 28rpx 10rpx 18rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border: 4rpx solid #ffffff;
  border-radius: 36rpx;
  box-sizing: border-box;
}

.search-input {
  width: 100%;
  height: 58rpx;
  color: #ffffff;
  font-size: 30rpx;
  text-align: center;
}

.search-placeholder {
  color: #ffffff;
}

.filter-bar {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 24rpx;
  align-items: center;
  margin: 0 10rpx 20rpx;
}

.filter-item {
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000000;
  font-size: 27rpx;
  font-weight: 700;
  white-space: nowrap;
}

.filter-arrow {
  margin-left: 6rpx;
  font-size: 42rpx;
  line-height: 1;
}

.active-filter-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin: 0 0 16rpx;
}

.active-filter,
.clear-filter {
  min-height: 38rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #222222;
  font-size: 22rpx;
}

.clear-filter {
  color: #c92a2a;
}

.activity-list {
  display: grid;
  gap: 18rpx;
}

.activity-card {
  position: relative;
  min-height: 154rpx;
  padding: 24rpx 24rpx 22rpx 176rpx;
  display: flex;
  align-items: center;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 5rpx 12rpx rgba(0, 0, 0, 0.12);
  box-sizing: border-box;
  overflow: visible;
}

.activity-image {
  position: absolute;
  left: 32rpx;
  top: 50%;
  width: 112rpx;
  height: 112rpx;
  transform: translateY(-50%);
}

.activity-info {
  min-width: 0;
}

.activity-title {
  margin-bottom: 12rpx;
  color: #000000;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.activity-line {
  color: #000000;
  font-size: 24rpx;
  line-height: 1.35;
}

.joined-count {
  color: #ff0000;
}

.status-ribbon {
  position: absolute;
  left: 0;
  top: -8rpx;
  z-index: 2;
  min-width: 138rpx;
  height: 42rpx;
  padding: 0 20rpx 0 22rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #000000;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.status-ribbon::after {
  content: "";
  position: absolute;
  right: -20rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 21rpx solid transparent;
  border-bottom: 21rpx solid transparent;
}

.status-pending {
  background: #f5f5f5;
}

.status-pending::after {
  border-left: 20rpx solid #f5f5f5;
}

.status-open {
  background: #b8dcff;
}

.status-open::after {
  border-left: 20rpx solid #b8dcff;
}

.status-closed {
  background: #c8f7b8;
}

.status-closed::after {
  border-left: 20rpx solid #c8f7b8;
}

.status-active {
  background: #ffe600;
}

.status-active::after {
  border-left: 20rpx solid #ffe600;
}

.status-ended {
  background: #d95be6;
}

.status-ended::after {
  border-left: 20rpx solid #d95be6;
}

.empty-text,
.end-text {
  margin-top: 42rpx;
  color: #000000;
  font-size: 26rpx;
  text-align: center;
}
