@import "./common.wxss";

.publish-wrap {
  padding-bottom: 80rpx;
}

.form-row {
  min-height: 70rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eeeeee;
}

.form-label {
  flex: 0 0 168rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 27rpx;
  color: #111111;
}

.form-row-textarea {
  align-items: flex-start;
  padding: 16rpx 0;
}

.form-row-textarea .form-label {
  padding-top: 8rpx;
}

.form-textarea {
  flex: 1;
  min-width: 0;
  height: 128rpx;
  font-size: 27rpx;
  color: #111111;
  line-height: 1.55;
}

.submit-publish {
  width: 100%;
  height: 78rpx;
  margin-top: 44rpx;
  border: 0;
  border-radius: 12rpx;
  background: #f4a8b8;
  color: #111111;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 78rpx;
}
