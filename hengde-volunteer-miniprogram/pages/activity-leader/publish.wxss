@import "./common.wxss";

.publish-wrap {
  padding-bottom: 80rpx;
}

.form-row {
  min-height: 70rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eeeeee;
}

.form-label {
  flex: 0 0 168rpx;
  font-size: 28rpx;
  font-weight: 800;
}

/* 必填项星号：与「我的资料」一致的珊瑚粉 */
.req-star {
  color: #ef7d7d;
  margin-right: 4rpx;
  font-weight: 800;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 27rpx;
  color: #111111;
}

/* 活动地点「定位」按钮：调起微信地图选点获取经纬度 */
.locate-btn {
  flex: none;
  margin-left: 12rpx;
  padding: 8rpx 22rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: #f4a8b8;
  border-radius: 28rpx;
}

.locate-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999999;
}

.form-row-cover {
  align-items: flex-start;
  padding: 16rpx 0;
}

.form-row-cover .form-label {
  padding-top: 8rpx;
}

.cover-uploader {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.cover-preview {
  width: 220rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: #f4f4f4;
}

.cover-placeholder {
  width: 220rpx;
  height: 150rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #cccccc;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.cover-plus {
  font-size: 48rpx;
  color: #bbbbbb;
  line-height: 1;
}

.cover-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.cover-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 8rpx;
}

.cover-action {
  font-size: 26rpx;
  color: #1677ff;
}

.cover-action-danger {
  color: #fa5151;
}

/* 离屏裁剪 canvas：移出可视区但保留在布局中（绘制缓冲尺寸由 JS 设，CSS 尺寸不影响导出） */
.cover-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 320rpx;
  height: 180rpx;
}

.form-row-textarea {
  align-items: flex-start;
  padding: 16rpx 0;
}

.form-row-textarea .form-label {
  padding-top: 8rpx;
}

.form-textarea {
  flex: 1;
  min-width: 0;
  height: 128rpx;
  font-size: 27rpx;
  color: #111111;
  line-height: 1.55;
}

.submit-publish {
  width: 100%;
  height: 78rpx;
  margin-top: 44rpx;
  border: 0;
  border-radius: 12rpx;
  background: #f4a8b8;
  color: #111111;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 78rpx;
}
