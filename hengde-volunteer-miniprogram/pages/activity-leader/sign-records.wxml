<view class="leader-page">
  <view class="leader-nav">
    <image class="back-icon" src="/assets/login/back-transparent.png" mode="aspectFit" bindtap="goBack"></image>
    <view class="nav-title">活动签到管理</view>
  </view>

  <view class="content-wrap">
    <view class="section-card">
      <view class="card-title">活动信息</view>
      <view class="info-line">活动名称：{{activity.name}}</view>
      <view class="info-line">活动地点：{{activity.location}}</view>
      <view class="info-line">活动时间：{{activity.time}}</view>
    </view>

    <view class="section-card record-card sign-record-card">
      <view class="center-title">签到记录</view>
      <view class="table-head sign-grid">
        <view>名字</view><view>电话</view><view>学校</view><view>操作</view>
      </view>
      <view class="table-row sign-grid" wx:for="{{records}}" wx:key="index">
        <view>{{item.name}}</view>
        <view>{{item.phone}}<text class="phone-dot">●</text></view>
        <view>{{item.school}}</view>
        <view><text class="status-tag {{item.statusClass}}">{{item.status}}</text></view>
      </view>
    </view>

    <view class="leader-grid">
      <view bindtap="openActivityDetail">活动详情</view>
      <view bindtap="startActivity">开始活动</view>
      <view bindtap="finishActivity">结束活动</view>
      <view bindtap="openSign">活动签到</view>
      <view class="danger" bindtap="emergencyReport">紧急上报</view>
      <view bindtap="openViolation">违规记录</view>
      <view bindtap="uploadPhoto">上传照片</view>
      <view bindtap="evaluateActivity">活动评价</view>
    </view>
  </view>
</view>
