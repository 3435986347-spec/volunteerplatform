.global-search-page {
  min-height: 100vh;
  padding: 0 30rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ff8faf 0%, #ffd2dc 32%, #fff7f5 100%);
  color: #111111;
}

.search-nav {
  position: relative;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.28);
}

.back-icon {
  position: absolute;
  left: 0;
  width: 58rpx;
  height: 58rpx;
}

.search-title {
  font-size: 38rpx;
  font-weight: 700;
}

.search-input-card {
  height: 70rpx;
  margin: 28rpx 0 22rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border: 4rpx solid #ffffff;
  border-radius: 38rpx;
  box-sizing: border-box;
}

.search-input {
  width: 100%;
  height: 60rpx;
  color: #ffffff;
  font-size: 30rpx;
  text-align: center;
}

.search-placeholder {
  color: #ffffff;
}

.result-list {
  display: grid;
  gap: 0;
  border: 2rpx solid rgba(0, 0, 0, 0.42);
  border-bottom: 0;
  background: rgba(255, 255, 255, 0.3);
}

.result-card {
  min-height: 112rpx;
  padding: 16rpx 20rpx;
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.42);
  box-sizing: border-box;
}

.cover-slot {
  width: 132rpx;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: #333333;
  font-size: 24rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
}

.empty-cover {
  background: rgba(255, 255, 255, 0.34);
}

.result-content {
  min-width: 0;
}

.result-title {
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-summary {
  margin-top: 6rpx;
  color: #333333;
  font-size: 25rpx;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-tag {
  margin-top: 8rpx;
  color: #111111;
  font-size: 23rpx;
}

.empty-state,
.load-more {
  margin-top: 40rpx;
  text-align: center;
  color: #111111;
  font-size: 26rpx;
}
