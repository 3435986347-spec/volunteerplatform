.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  height: 116rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e6e8ee;
  background: #ffffff;
  box-sizing: content-box;
  font-family: "FZDFS--GBK1-0";
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-family: "FZDFS--GBK1-0";
}

.tab-icon {
  width: 62rpx;
  height: 62rpx;
}

.tab-text {
  margin-top: 2rpx;
  font-family: "FZDFS--GBK1-0";
  font-size: 24rpx;
  line-height: 1.2;
}
