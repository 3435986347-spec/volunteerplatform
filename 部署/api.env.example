# ============================================================
# 恒德志愿者平台 API · 生产环境变量模板（systemd EnvironmentFile 格式）
#
# 用法：复制到服务器 /etc/hengde/api.env 并填入真实值：
#   install -D -m 600 api.env.example /etc/hengde/api.env && vi /etc/hengde/api.env
# 留空的 ✅ 项不填会被 ProductionConfigGuard 拒绝启动（fail-fast，预期行为）。
# 变量含义与第三方开通步骤详见 文档/v1/上线checklist.md 第 4/5 节。
# ============================================================

# ===== profile（✅ 必填；不设 prod 会被守卫拦下）=====
SPRING_PROFILES_ACTIVE=prod

# ===== 数据库（✅ 别用 root/root；先建空库 hengde_volunteer utf8mb4）=====
DB_USER=hengde
DB_PWD=
# MySQL 不在本机时覆盖整条 url：
# SPRING_DATASOURCE_URL=jdbc:mysql://<host>:3306/hengde_volunteer?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai

# ===== Redis（生产务必设密码，不要裸跑公网）=====
SPRING_DATA_REDIS_PASSWORD=
# 不在本机时再覆盖：
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_DATA_REDIS_PORT=6379

# ===== PII 加密密钥（✅✅ 最关键）=====
# 身份证/手机号用它加密入库。⚠️ 首次写入真实数据前定好，之后绝不能更换或丢失——
# 换了/丢了，库里已加密的 PII 全部无法解密。用强随机串（如 openssl rand -base64 32），离库备份保管。
SECURITY_AES_KEY=
SECURITY_HMAC_KEY=

# ===== 初始超管（✅ 首次启动前就设强密码；admin123 会被守卫拒启）=====
AUTH_SUPER_ADMIN_USERNAME=admin
AUTH_SUPER_ADMIN_PASSWORD=

# ===== 微信小程序（✅ 志愿者端必需；后台管理端不依赖）=====
WX_APPID=
WX_SECRET=

# ===== 短信 · 火山引擎（✅ 不开则注册/找回密码收不到验证码）=====
SMS_ENABLED=true
SMS_AK=
SMS_SK=
# 消息组 ID（注意：不是火山账号 ID），短信控制台里创建，形如 A123456
SMS_ACCOUNT=
# 验证码模板 ID（形如 ST_6f8c...）。每条模板的变量名都必须是 code，即正文写 ${code}。
# 分场景各配一条文案才贴切；只填 SMS_TPL_VERIFY 则所有场景共用它（注册也会收到登录文案）。
SMS_TPL_VERIFY=
SMS_TPL_REGISTER=
SMS_TPL_LOGIN=
SMS_TPL_PWD_RESET=
SMS_TPL_ADMIN_PWD_RESET=
SMS_TPL_CHANGE_PHONE=

# ===== 对象存储（✅ 不开则上传全是占位 URL）；恒德实例用火山 TOS =====
OSS_PROVIDER=volc
OSS_ENABLED=true
OSS_ENDPOINT=
OSS_REGION=
OSS_BUCKET=hengde-volunteer
OSS_AK=
OSS_SK=
# 绑了 CDN/自定义域名再填：
OSS_URL_PREFIX=

# ===== 志愿者协议（✅ 守卫强校验：版本非空、正文非占位）=====
AUTH_AGREEMENT_VERSION=1.0
# 协议正文（hengde.auth.agreement-text）是长文本，不适合放环境变量——
# 推荐写进 /opt/hengde/api/config/application-prod.yaml（见 部署说明.md 第 2 节示例）。

# ===== 功能开关 =====
# 实名二要素（腾讯云 faceid IdCardVerification，按次计费；仅「一致/不一致」两种结果收费）。
# 置 true 必须同时填下面两个密钥，否则 ProductionConfigGuard 拒绝启动；
# false 时只校验身份证号格式后放行，不调第三方、不产生费用。
AUTH_REALNAME_ENABLED=false
# 腾讯云控制台 → 访问管理(CAM) → API 密钥管理；与火山引擎的 AK/SK 无关，不可复用
REALNAME_SECRET_ID=
REALNAME_SECRET_KEY=
# 企业微信群校验 + 引导入群二维码
AUTH_WEWORK_ENABLED=false
AUTH_WEWORK_QR_URL=
# 开发登录：生产必须 false（true 会被守卫拒启）
AUTH_DEV_LOGIN_ENABLED=false

# ===== 可选 =====
# 活动现场「紧急上报」预设电话（hengde.activity.emergency-phone，小程序负责人端 tel: 拨号）
HENGDE_ACTIVITY_EMERGENCYPHONE=
# 日志级别（默认 INFO）
# LOGGING_LEVEL_COM_HENGDE=INFO
